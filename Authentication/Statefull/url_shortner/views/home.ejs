<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Snipr — Shorten links. Protect them. Track them.' %></title>
  <meta name="description" content="Snipr turns long URLs into short, secure, trackable links — with password protection, one-time links, and expiry built in." />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/home.css" />
</head>
<body>

  <!-- ===================== NAVBAR ===================== -->
  <header class="navbar">
    <div class="navbar__inner">
      <a href="/" class="brand">
        <span class="brand__mark" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9.5 14.5L14.5 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M11 6.5L12.5 5C14.4 3.1 17.5 3.1 19.4 5C21.3 6.9 21.3 10 19.4 11.9L17.9 13.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M13 17.5L11.5 19C9.6 20.9 6.5 20.9 4.6 19C2.7 17.1 2.7 14 4.6 12.1L6.1 10.6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="brand__name">Snipr</span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/analytics" class="nav-link">Analytics</a>
      </nav>

      <div class="navbar__actions">
        <a href="/signin" class="btn btn--ghost">Sign in</a>
        <a href="/signup" class="btn btn--primary">Sign up free</a>
      </div>

      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="mobile-menu" id="mobileMenu">
      <a href="/dashboard" class="nav-link">Dashboard</a>
      <a href="/analytics" class="nav-link">Analytics</a>
      <div class="mobile-menu__actions">
        <a href="/signin" class="btn btn--ghost">Sign in</a>
        <a href="/signup" class="btn btn--primary">Sign up free</a>
      </div>
    </div>
  </header>

  <main>
    <!-- ===================== HERO + SHORTENER ===================== -->
    <section class="hero">
      <div class="hero__glow hero__glow--one" aria-hidden="true"></div>
      <div class="hero__glow hero__glow--two" aria-hidden="true"></div>

      <div class="hero__inner">
        <span class="eyebrow">Links, reimagined</span>
        <h1 class="hero__title">
          Shorten your links.<br />
          <span class="hero__title-accent">Guard what matters.</span>
        </h1>
        <p class="hero__subtitle">
          Turn long, messy URLs into short, branded links in seconds — with password
          protection, one-time access, and expiry dates built right in.
        </p>

        <!-- URL Shortener Form -->
        <form class="shortener-card" id="shortenerForm" action="/" method="POST" novalidate>
          <div class="shortener-card__glass" aria-hidden="true"></div>

          <div class="field field--url">
            <label for="urlInput" class="sr-only">Enter your long URL</label>
            <svg class="field__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M9.5 14.5L14.5 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M11 6.5L12.5 5C14.4 3.1 17.5 3.1 19.4 5C21.3 6.9 21.3 10 19.4 11.9L17.9 13.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M13 17.5L11.5 19C9.6 20.9 6.5 20.9 4.6 19C2.7 17.1 2.7 14 4.6 12.1L6.1 10.6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <input
              type="url"
              id="urlInput"
              name="url"
              class="field__input field__input--lg"
              placeholder="Paste a long URL — https://example.com/your-very-long-link"
              required
              autocomplete="off"
            />
          </div>

          <div class="shortener-card__options">
            <div class="option-toggle" data-option="expiry">
              <label class="option-toggle__label" for="expiryToggle">
                <svg class="option-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.7"/>
                  <path d="M12 8V12L14.5 14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Expiry date</span>
              </label>
              <input type="checkbox" id="expiryToggle" class="switch" data-toggle-target="expiryField" />
              <input
                type="datetime-local"
                id="expiryField"
                name="expiresAt"
                class="option-toggle__field"
                aria-label="Set expiry date and time"
                disabled/
              />
            </div>

            <div class="option-toggle" data-option="onetime">
              <label class="option-toggle__label" for="oneTimeToggle">
                <svg class="option-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 3L20 7V11.5C20 16.2 16.9 20.3 12 21.5C7.1 20.3 4 16.2 4 11.5V7L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                  <path d="M9 12L11 14L15.5 9.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>One-time link</span>
              </label>
              <input type="checkbox" id="oneTimeToggle" name="oneTime" class="switch" />
            </div>

            <div class="option-toggle option-toggle--password" data-option="password">
              <label class="option-toggle__label" for="passwordToggle">
                <svg class="option-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.7"/>
                  <path d="M8 11V7.5C8 5 9.8 3.5 12 3.5C14.2 3.5 16 5 16 7.5V11" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                </svg>
                <span>Password protect</span>
              </label>
              <input type="checkbox" id="passwordToggle" class="switch" data-toggle-target="passwordField" />
              <input
                type="password"
                id="passwordField"
                name="password"
                class="option-toggle__field"
                placeholder="Enter password"
                aria-label="Set link password"
                disabled
              />
            </div>
          </div>

          <button type="submit" class="btn btn--cta shortener-card__submit">
            <span>Generate short URL</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M13 6L19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <% if (typeof shortUrl !== 'undefined' && shortUrl) { %>
            <div class="result-banner" role="status">
              <span class="result-banner__label">Your short link is ready</span>
              <div class="result-banner__row">
                <code class="result-banner__url"><%= shortUrl %></code>
                <button type="button" class="btn btn--copy" data-copy="<%= shortUrl %>">Copy</button>
              </div>
            </div>
          <% } %>
        </form>

        <div class="hero__trust">
          <span>No credit card required</span>
          <span class="dot" aria-hidden="true">•</span>
          <span>Free for up to 50 links/mo</span>
          <span class="dot" aria-hidden="true">•</span>
          <span>Cancel anytime</span>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURES ===================== -->
    <section class="section features" id="features">
      <div class="section__inner">
        <span class="eyebrow eyebrow--center">Why Snipr</span>
        <h2 class="section__title">Everything a link needs to work harder</h2>
        <p class="section__subtitle">Built for teams who care what happens after someone clicks.</p>

        <div class="features__grid">
          <article class="feature-card">
            <div class="feature-card__icon feature-card__icon--indigo">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M13 2L4 14H12L11 22L20 10H12L13 2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Instant shortening</h3>
            <p class="feature-card__text">Paste any URL and get a clean, branded short link in under a second — no friction, no sign-up wall.</p>
          </article>

          <article class="feature-card">
            <div class="feature-card__icon feature-card__icon--coral">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="3" y="11" width="18" height="10" rx="2.5" stroke="currentColor" stroke-width="1.7"/>
                <path d="M7 11V7.5C7 4.5 9.2 2.5 12 2.5C14.8 2.5 17 4.5 17 7.5V11" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Password protection</h3>
            <p class="feature-card__text">Lock sensitive links behind a password so only the people you trust can open them.</p>
          </article>

          <article class="feature-card">
            <div class="feature-card__icon feature-card__icon--indigo">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3 12C3 12 6.5 5 12 5C17.5 5 21 12 21 12C21 12 17.5 19 12 19C6.5 19 3 12 3 12Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.7"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Real-time analytics</h3>
            <p class="feature-card__text">See every click as it happens — location, device, and referrer, without the spreadsheet.</p>
          </article>

          <article class="feature-card">
            <div class="feature-card__icon feature-card__icon--coral">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.7"/>
                <path d="M12 7.5V12L15 14.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Expiring links</h3>
            <p class="feature-card__text">Set a link to self-destruct at a specific date and time — perfect for limited-time offers.</p>
          </article>

          <article class="feature-card">
            <div class="feature-card__icon feature-card__icon--indigo">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 3L20 7V11.5C20 16.2 16.9 20.3 12 21.5C7.1 20.3 4 16.2 4 11.5V7L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                <path d="M9 12L11 14L15.5 9.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feature-card__title">One-time links</h3>
            <p class="feature-card__text">Generate a link that works exactly once, then disables itself automatically.</p>
          </article>

          <article class="feature-card">
            <div class="feature-card__icon feature-card__icon--coral">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="3.5" y="4" width="17" height="16" rx="2.5" stroke="currentColor" stroke-width="1.7"/>
                <path d="M3.5 9H20.5" stroke="currentColor" stroke-width="1.7"/>
                <path d="M8 2.5V5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                <path d="M16 2.5V5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feature-card__title">Link history</h3>
            <p class="feature-card__text">Every link you've ever created, searchable and organized in one dashboard.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===================== SECURITY FEATURES ===================== -->
    <section class="section security" id="security">
      <div class="section__inner">
        <span class="eyebrow eyebrow--center">Built-in security</span>
        <h2 class="section__title">Control exactly who gets through</h2>
        <p class="section__subtitle">Three ways to keep your links exactly as private as you need them to be.</p>

        <div class="security__grid">
          <article class="security-card">
            <div class="security-card__visual security-card__visual--password" aria-hidden="true">
              <svg width="34" height="34" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"/>
                <path d="M8 11V7.5C8 5 9.8 3.5 12 3.5C14.2 3.5 16 5 16 7.5V11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <circle cx="12" cy="15.2" r="1.3" fill="currentColor"/>
              </svg>
            </div>
            <h3 class="security-card__title">Password-protected links</h3>
            <p class="security-card__text">
              Add a password to any link. Visitors must enter it correctly before they're redirected —
              ideal for client deliverables, internal docs, or private invites.
            </p>
          </article>

          <article class="security-card">
            <div class="security-card__visual security-card__visual--onetime" aria-hidden="true">
              <svg width="34" height="34" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3L20 7V11.5C20 16.2 16.9 20.3 12 21.5C7.1 20.3 4 16.2 4 11.5V7L12 3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M9 12L11 14L15.5 9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="security-card__title">One-time links</h3>
            <p class="security-card__text">
              Create a link that self-destructs the moment it's clicked. Perfect for sharing
              sensitive files, secrets, or single-use offers with zero residual access.
            </p>
          </article>

          <article class="security-card">
            <div class="security-card__visual security-card__visual--expiry" aria-hidden="true">
              <svg width="34" height="34" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.6"/>
                <path d="M12 7.5V12L15 14.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="security-card__title">Expiring links</h3>
            <p class="security-card__text">
              Pick the exact date and time a link should stop working. Great for flash sales,
              event registrations, or anything with a shelf life.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===================== ANALYTICS PREVIEW ===================== -->
    <section class="section analytics-preview" id="analytics-preview">
      <div class="section__inner analytics-preview__inner">
        <div class="analytics-preview__copy">
          <span class="eyebrow">Analytics</span>
          <h2 class="section__title section__title--left">Know exactly who's clicking</h2>
          <p class="section__subtitle section__subtitle--left">
            Every short link comes with a real-time dashboard — clicks over time, top
            locations, referrers, and devices. No setup, no extra tab to manage.
          </p>
          <ul class="analytics-preview__list">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 13L9.5 17.5L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Live click tracking, updated in real time
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 13L9.5 17.5L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Geographic breakdown by country and city
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 13L9.5 17.5L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Device, browser, and referrer insights
            </li>
          </ul>
          <a href="/analytics" class="btn btn--primary">Explore analytics</a>
        </div>

        <div class="analytics-preview__visual">
          <div class="dash-card">
            <div class="dash-card__header">
              <span class="dash-card__title">Link performance</span>
              <span class="dash-card__badge">Last 7 days</span>
            </div>
            <div class="dash-card__stats">
              <div class="dash-stat">
                <span class="dash-stat__value">12,482</span>
                <span class="dash-stat__label">Total clicks</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat__value">3,910</span>
                <span class="dash-stat__label">Unique visitors</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat__value">68%</span>
                <span class="dash-stat__label">CTR</span>
              </div>
            </div>
            <div class="dash-card__chart" aria-hidden="true">
              <svg viewBox="0 0 320 110" preserveAspectRatio="none" width="100%" height="110">
                <defs>
                  <linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#4F46E5" stop-opacity="0.35"/>
                    <stop offset="100%" stop-color="#4F46E5" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0,80 L40,65 L80,72 L120,45 L160,55 L200,30 L240,38 L280,15 L320,22 L320,110 L0,110 Z" fill="url(#chartFill)"/>
                <path d="M0,80 L40,65 L80,72 L120,45 L160,55 L200,30 L240,38 L280,15 L320,22" fill="none" stroke="#4F46E5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="dash-card__footer">
              <div class="dash-card__row"><span>🇺🇸 United States</span><span>42%</span></div>
              <div class="dash-card__row"><span>🇮🇳 India</span><span>27%</span></div>
              <div class="dash-card__row"><span>🇬🇧 United Kingdom</span><span>14%</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CTA SECTION ===================== -->
    <section class="cta">
      <div class="cta__inner">
        <h2 class="cta__title">Your links deserve better than a wall of random characters.</h2>
        <p class="cta__subtitle">Join thousands of teams shortening, securing, and tracking their links with Snipr.</p>
        <div class="cta__actions">
          <a href="/signup" class="btn btn--cta">Get started — it's free</a>
          <a href="#features" class="btn btn--ghost btn--ghost-dark">See features</a>
        </div>
      </div>
    </section>
  </main>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="footer__inner">
      <div class="footer__brand">
        <a href="/" class="brand brand--footer">
          <span class="brand__mark" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.5 14.5L14.5 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M11 6.5L12.5 5C14.4 3.1 17.5 3.1 19.4 5C21.3 6.9 21.3 10 19.4 11.9L17.9 13.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M13 17.5L11.5 19C9.6 20.9 6.5 20.9 4.6 19C2.7 17.1 2.7 14 4.6 12.1L6.1 10.6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="brand__name">Snipr</span>
        </a>
        <p class="footer__tagline">Short links. Strong control.</p>
      </div>

      <nav class="footer__col" aria-label="Product">
        <h4>Product</h4>
        <a href="/dashboard">Dashboard</a>
        <a href="/analytics">Analytics</a>
        <a href="#security">Security</a>
        <a href="#features">Features</a>
      </nav>

      <nav class="footer__col" aria-label="Company">
        <h4>Company</h4>
        <a href="/about">About</a>
        <a href="/pricing">Pricing</a>
        <a href="/contact">Contact</a>
      </nav>

      <nav class="footer__col" aria-label="Legal">
        <h4>Legal</h4>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>
    </div>
    <div class="footer__bottom">
      <p>&copy; <%= new Date().getFullYear() %> Snipr. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    const navToggle = document.getElementById('navToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    navToggle.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('mobile-menu--open');
      navToggle.classList.toggle('nav-toggle--open', isOpen);
      navToggle.setAttribute('aria-expanded', isOpen);
    });

    // Enable/disable paired fields when their switch is toggled
    document.querySelectorAll('.switch[data-toggle-target]').forEach((toggle) => {
      const target = document.getElementById(toggle.dataset.toggleTarget);
      toggle.addEventListener('change', () => {
        target.disabled = !toggle.checked;
        if (toggle.checked) target.focus();
      });
    });

    // Copy short URL to clipboard
    document.querySelectorAll('[data-copy]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy);
          const original = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => (btn.textContent = original), 1800);
        } catch (err) {
          console.error('Copy failed', err);
        }
      });
    });
  </script>
</body>
</html>
