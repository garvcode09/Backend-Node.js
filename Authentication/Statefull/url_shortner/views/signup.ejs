<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Account — Snipr</title>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Signup Stylesheet -->
  <link rel="stylesheet" href="/css/signup.css" />
</head>
<body>

  <!-- =========================================================
       Background decorative blobs (pure CSS, no images)
  ========================================================= -->
  <div class="bg-blob bg-blob--1" aria-hidden="true"></div>
  <div class="bg-blob bg-blob--2" aria-hidden="true"></div>

  <!-- =========================================================
       Main centered wrapper
  ========================================================= -->
  <main class="page-wrapper" role="main">

    <!-- ── Card ────────────────────────────────────────────── -->
    <div class="card" role="region" aria-labelledby="card-heading">

      <!-- ── Brand / Logo ──────────────────────────────────── -->
      <div class="brand">
        <div class="brand__logo" aria-hidden="true">
          <!-- Lightning bolt SVG icon -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
               xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
                  fill="currentColor" stroke="currentColor"
                  stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="brand__name">Snipr</span>
      </div>

      <!-- ── Heading ───────────────────────────────────────── -->
      <div class="card__header">
        <h1 class="card__title" id="card-heading">Create your account</h1>
      
      </div>

      <!-- ── Flash Messages (EJS conditional) ─────────────── -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash flash--error" role="alert" aria-live="assertive">
          <!-- Error icon -->
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
               xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="12" cy="16" r="1" fill="currentColor"/>
          </svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="flash flash--success" role="status" aria-live="polite">
          <!-- Check icon -->
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
               xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span><%= success %></span>
        </div>
      <% } %>

      <!-- ── Signup Form ────────────────────────────────────── -->
      <form
        class="form"
        id="signupForm"
        action="/user/signup"
        method="POST"
        novalidate
        aria-label="Sign up form"
      >

        <!-- Username -->
        <div class="field" id="field-username">
          <label class="field__label" for="username">Username</label>
          <div class="field__input-wrap">
            <!-- User icon -->
            <svg class="field__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.75"/>
              <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7" stroke="currentColor"
                    stroke-width="1.75" stroke-linecap="round"/>
            </svg>
            <input
              class="field__input"
              type="text"
              id="username"
              name="username"
              placeholder="johndoe"
              autocomplete="username"
              spellcheck="false"
              required
              minlength="3"
              maxlength="32"
              aria-required="true"
              aria-describedby="username-hint username-error"
            />
          </div>
          <span class="field__hint" id="username-hint">3–32 characters, letters and numbers only.</span>
          <span class="field__error" id="username-error" role="alert" aria-live="polite"></span>
        </div>

        <!-- Email -->
        <div class="field" id="field-email">
          <label class="field__label" for="email">Email address</label>
          <div class="field__input-wrap">
            <!-- Email icon -->
            <svg class="field__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75"/>
              <path d="M2 8l10 7 10-7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
            <input
              class="field__input"
              type="email"
              id="email"
              name="email"
              placeholder="john@example.com"
              autocomplete="email"
              spellcheck="false"
              required
              aria-required="true"
              aria-describedby="email-error"
            />
          </div>
          <span class="field__error" id="email-error" role="alert" aria-live="polite"></span>
        </div>

        <!-- Password -->
        <div class="field" id="field-password">
          <label class="field__label" for="password">Password</label>
          <div class="field__input-wrap">
            <!-- Lock icon -->
            <svg class="field__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.75"/>
              <path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor"
                    stroke-width="1.75" stroke-linecap="round"/>
              <circle cx="12" cy="16" r="1.25" fill="currentColor"/>
            </svg>
            <input
              class="field__input field__input--password"
              type="password"
              id="password"
              name="password"
              placeholder="Min. 8 characters"
              autocomplete="new-password"
              required
              minlength="8"
              aria-required="true"
              aria-describedby="password-strength password-error"
            />
            <!-- Visibility toggle -->
            <button
              class="field__toggle"
              type="button"
              id="togglePassword"
              aria-label="Show password"
              aria-controls="password"
              aria-pressed="false"
              tabindex="0"
            >
              <!-- Eye open -->
              <svg class="toggle-icon toggle-icon--show" width="18" height="18"
                   viewBox="0 0 24 24" fill="none"
                   xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12z"
                      stroke="currentColor" stroke-width="1.75"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.75"/>
              </svg>
              <!-- Eye closed -->
              <svg class="toggle-icon toggle-icon--hide" width="18" height="18"
                   viewBox="0 0 24 24" fill="none"
                   xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"
                      stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"
                      stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor"
                      stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </button>
          </div>

          <!-- Password strength meter -->
          <div class="strength" id="password-strength" aria-label="Password strength" role="status">
            <div class="strength__bars" aria-hidden="true">
              <span class="strength__bar"></span>
              <span class="strength__bar"></span>
              <span class="strength__bar"></span>
              <span class="strength__bar"></span>
            </div>
            <span class="strength__label" id="strength-label"></span>
          </div>

          <span class="field__error" id="password-error" role="alert" aria-live="polite"></span>
        </div>

        <!-- Confirm Password -->
        <div class="field" id="field-confirm">
          <label class="field__label" for="confirmPassword">Confirm password</label>
          <div class="field__input-wrap">
            <!-- Shield icon -->
            <svg class="field__icon" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z"
                    stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.75"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <input
              class="field__input field__input--password"
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Repeat your password"
              autocomplete="new-password"
              required
              aria-required="true"
              aria-describedby="confirm-error"
            />
            <!-- Visibility toggle (confirm) -->
            <button
              class="field__toggle"
              type="button"
              id="toggleConfirm"
              aria-label="Show confirm password"
              aria-controls="confirmPassword"
              aria-pressed="false"
              tabindex="0"
            >
              <svg class="toggle-icon toggle-icon--show" width="18" height="18"
                   viewBox="0 0 24 24" fill="none"
                   xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12z"
                      stroke="currentColor" stroke-width="1.75"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.75"/>
              </svg>
              <svg class="toggle-icon toggle-icon--hide" width="18" height="18"
                   viewBox="0 0 24 24" fill="none"
                   xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"
                      stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"
                      stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                <line x1="1" y1="1" x2="23" y2="23" stroke="currentColor"
                      stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <span class="field__error" id="confirm-error" role="alert" aria-live="polite"></span>
        </div>

        <!-- Submit Button -->
        <button
          class="btn-submit"
          type="submit"
          id="submitBtn"
          aria-label="Create your account"
        >
          <!-- Default label -->
          <span class="btn-submit__label">Create Account</span>

          <!-- Loading spinner (hidden by default) -->
          <span class="btn-submit__spinner" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,0.3)" stroke-width="2.5"/>
              <path d="M12 2a10 10 0 0 1 10 10" stroke="white" stroke-width="2.5"
                    stroke-linecap="round"/>
            </svg>
            <span>Creating account…</span>
          </span>
        </button>

      </form>
      <!-- /form -->

      <!-- ── Footer link ────────────────────────────────────── -->
      <p class="card__footer">
        Already have an account?
        <a class="card__login-link" href="/login">Log in</a>
      </p>

      <!-- ── Divider + Social proof ─────────────────────────── -->
      <div class="social-proof" aria-label="Trust signal">
        <div class="social-proof__divider" aria-hidden="true"></div>
        <p class="social-proof__text">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Your data is encrypted &amp; never shared
        </p>
      </div>

    </div>
    <!-- /card -->

  </main>

  <!-- =========================================================
       Inline script — progressive enhancement only
       (validation + toggle + loading state)
  ========================================================= -->
  <script>
    /* ── Utility helpers ── */
    const $ = (sel) => document.querySelector(sel);
    const field = (id) => document.getElementById('field-' + id);
    const err   = (id) => document.getElementById(id + '-error');

    function setValid(fieldId) {
      const f = field(fieldId);
      if (!f) return;
      f.classList.remove('field--error');
      f.classList.add('field--valid');
      const e = err(fieldId);
      if (e) e.textContent = '';
    }

    function setError(fieldId, msg) {
      const f = field(fieldId);
      if (!f) return;
      f.classList.remove('field--valid');
      f.classList.add('field--error');
      const e = err(fieldId);
      if (e) e.textContent = msg;
    }

    function clearState(fieldId) {
      const f = field(fieldId);
      if (!f) return;
      f.classList.remove('field--valid', 'field--error');
      const e = err(fieldId);
      if (e) e.textContent = '';
    }

    /* ── Password visibility toggles ── */
    function setupToggle(btnId, inputId) {
      const btn   = document.getElementById(btnId);
      const input = document.getElementById(inputId);
      if (!btn || !input) return;

      btn.addEventListener('click', () => {
        const isHidden = input.type === 'password';
        input.type     = isHidden ? 'text' : 'password';
        btn.setAttribute('aria-label',   isHidden ? 'Hide password' : 'Show password');
        btn.setAttribute('aria-pressed', isHidden ? 'true' : 'false');
        btn.classList.toggle('is-visible', isHidden);
      });
    }

    setupToggle('togglePassword', 'password');
    setupToggle('toggleConfirm',  'confirmPassword');

    /* ── Password strength meter ── */
    const passwordInput = document.getElementById('password');
    const bars          = document.querySelectorAll('.strength__bar');
    const strengthLabel = document.getElementById('strength-label');
    const strengthWrap  = document.getElementById('password-strength');

    const levels = [
      { label: '',       cls: ''                },
      { label: 'Weak',   cls: 'strength--weak'  },
      { label: 'Fair',   cls: 'strength--fair'  },
      { label: 'Good',   cls: 'strength--good'  },
      { label: 'Strong', cls: 'strength--strong'},
    ];

    function getStrength(pw) {
      let score = 0;
      if (pw.length >= 8)  score++;
      if (pw.length >= 12) score++;
      if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) score++;
      if (/[0-9]/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;
      return Math.min(4, Math.ceil(score * 0.8));
    }

    passwordInput.addEventListener('input', () => {
      const val   = passwordInput.value;
      const score = val.length ? getStrength(val) : 0;

      /* Reset all classes */
      strengthWrap.className = 'strength';
      if (score > 0) strengthWrap.classList.add(levels[score].cls);

      bars.forEach((bar, i) => {
        bar.classList.toggle('is-active', i < score);
      });

      strengthLabel.textContent = val.length ? levels[score].label : '';
      strengthWrap.setAttribute('aria-label', 'Password strength: ' + (val.length ? levels[score].label : 'none'));
    });

    /* ── Live validation ── */
    document.getElementById('username').addEventListener('blur', function () {
      const v = this.value.trim();
      if (!v) {
        setError('username', 'Username is required.');
      } else if (v.length < 3) {
        setError('username', 'At least 3 characters needed.');
      } else if (!/^[A-Za-z0-9_]+$/.test(v)) {
        setError('username', 'Only letters, numbers, and underscores.');
      } else {
        setValid('username');
      }
    });

    document.getElementById('email').addEventListener('blur', function () {
      const v = this.value.trim();
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!v) {
        setError('email', 'Email address is required.');
      } else if (!re.test(v)) {
        setError('email', 'Enter a valid email address.');
      } else {
        setValid('email');
      }
    });

    document.getElementById('password').addEventListener('blur', function () {
      const v = this.value;
      if (!v) {
        setError('password', 'Password is required.');
      } else if (v.length < 8) {
        setError('password', 'Password must be at least 8 characters.');
      } else {
        setValid('password');
      }
    });

    document.getElementById('confirmPassword').addEventListener('blur', function () {
      const pw  = document.getElementById('password').value;
      const v   = this.value;
      if (!v) {
        setError('confirm', 'Please confirm your password.');
      } else if (v !== pw) {
        setError('confirm', 'Passwords do not match.');
      } else {
        setValid('confirm');
      }
    });

    /* ── Form submit: loading state ── */
    document.getElementById('signupForm').addEventListener('submit', function (e) {
      const btn = document.getElementById('submitBtn');
      btn.classList.add('is-loading');
      btn.disabled = true;

      /* Re-enable after 6s as safety fallback */
      setTimeout(() => {
        btn.classList.remove('is-loading');
        btn.disabled = false;
      }, 6000);
    });
  </script>

</body>
</html>
