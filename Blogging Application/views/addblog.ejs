<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
   <%- include('./partials/navbar') %>

<form action="/blog/create" method="POST" enctype="multipart/form-data" style="max-width: 600px; margin: 40px auto; padding: 32px; background: #ffffff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">

<!-- CoverImage field  -->
  <div class="form-group" style="margin-bottom: 24px;">
    <label for="coverImage" style="display: block; margin-bottom: 8px; font-weight: 600; color: #1f2937; font-size: 14px;">Cover Image</label>
    <input
      type="file"
      id="coverImage"
      name="coverImage"
      accept="image/*"
      required
      style="width: 100%; padding: 10px; border: 2px dashed #d1d5db; border-radius: 8px; background: #f9fafb; font-size: 14px; cursor: pointer; box-sizing: border-box;"
    >
  </div>

<!-- Title field -->
<div class="form-group" style="margin-bottom: 24px;">
    <label for="title" style="display: block; margin-bottom: 8px; font-weight: 600; color: #1f2937; font-size: 14px;">Blog Title</label>
    <input
        type="text"
        id="title"
        name="title"
        placeholder="Enter your blog title"
        maxlength="100"
        required
        style="width: 100%; padding: 12px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 15px; box-sizing: border-box; outline: none; transition: border-color 0.2s;"
        onfocus="this.style.borderColor='#6366f1'"
        onblur="this.style.borderColor='#d1d5db'"
    >
</div>

<!-- textarea field  -->
<div class="form-group" style="margin-bottom: 28px;">
    <label for="body" style="display: block; margin-bottom: 8px; font-weight: 600; color: #1f2937; font-size: 14px;">Blog Content</label>
    <textarea
        id="body"
        name="body"
        rows="12"
        placeholder="Write your blog here..."
        required
        style="width: 100%; padding: 12px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 15px; font-family: inherit; resize: vertical; box-sizing: border-box; outline: none; line-height: 1.6; transition: border-color 0.2s;"
        onfocus="this.style.borderColor='#6366f1'"
        onblur="this.style.borderColor='#d1d5db'"
    ></textarea>
</div>

  <button type="submit" style="width: 100%; padding: 14px; background: #6366f1; color: #ffffff; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#4f46e5'" onmouseout="this.style.background='#6366f1'">Publish Blog</button>

</form>








   <%- include('./partials/footer') %>
</body>
</html>
